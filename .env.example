# API logging: silent | error | warn | info | debug (default warn). Per-request HTTP logs are always off.
LOG_LEVEL=warn

# Google Auth (Service Account)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_DRIVE_ROOT_FOLDER_ID=
# Email of a user who has access to the Shared Drive (for impersonation)
GOOGLE_IMPERSONATE_USER=

# Or OAuth (for personal accounts)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/callback

# Gemini AI
GEMINI_API_KEY=

# Processing
TEMP_DIR=/tmp/drive-compressor
# Drive API download streams (1 = strictly one at a time)
MAX_CONCURRENT_DOWNLOADS=1
# Drive uploads (1 = one upload at a time)
MAX_CONCURRENT_UPLOADS=1
# Parallel FFmpeg encodes while download/upload stay serialized
MAX_PARALLEL_ENCODES=2
# Per compress/download job: needs ~2× file size (GiB) free under TEMP_DIR and under this cap
MAX_DISK_USAGE_GB=128

# Database
DATABASE_URL=file:./data/drive-compressor.db
